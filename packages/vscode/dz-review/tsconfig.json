{
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "ES2020",
    "outDir": "out",
    "lib": [
      "ES2020"
    ],
    "types": [
      "node"
    ],
    "sourceMap": true,
    "rootDir": "../../",
    "strict": true,
    "allowImportingTsExtensions": true
  },
  "exclude": [
    "node_modules",
    ".vscode-test",
    "test.ts"
  ]
}
